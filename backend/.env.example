# Copy this file to .env and fill in real values (never commit .env).

# Required in production: a long random string, never reused across
# environments. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Test/sandbox credentials come from your Mercado Pago developer panel:
# https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Must be a real, publicly reachable HTTPS URL in production and whenever
# testing Checkout Pro against the real Mercado Pago API - it's used as
# back_urls.success, and Mercado Pago rejects auto_return with a
# non-public/non-HTTPS back_url ("auto_return invalid. back_url.success
# must be defined"). Leave unset for plain local dev (console email
# backend, no real MP calls); set to an ngrok/tunnel HTTPS URL to test
# Checkout Pro locally, and to the real frontend domain in production.
FRONTEND_URL=http://localhost:5173

# Email (Brevo SMTP relay) - leave both blank to keep printing emails to
# the console in dev. Get these from the Brevo dashboard: SMTP & API >
# SMTP tab (login is your Brevo account email, password is the generated
# SMTP key, not your account password). DEFAULT_FROM_EMAIL must be an
# address on the domain verified in Brevo (sonhosliterarios.com.br) or
# sends will be rejected/spam-folded.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Sonhos Literários <naoresponda@sonhosliterarios.com.br>
