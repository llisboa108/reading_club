# Copy this file to .env and fill in real values (never commit .env).

# Required in production: a long random string, never reused across
# environments. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=

# Test/sandbox credentials come from your Mercado Pago developer panel:
# https://www.mercadopago.com.br/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# Email (Mailgun SMTP relay) - leave both blank to keep printing emails to
# the console in dev. Get these from the Mailgun dashboard: Sending >
# Domain settings > SMTP credentials. EMAIL_HOST/EMAIL_PORT/EMAIL_USE_TLS
# only need to be set if they differ from Mailgun's defaults below.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_HOST=smtp.mailgun.org
EMAIL_PORT=587
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=Sonhos Literários <no-reply@sonhosliterarios.com.br>
